{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CleanedJob",
  "type": "object",
  "required": [
    "job_id",
    "job_name",
    "job_category",
    "company_name",
    "industry",
    "company_scale",
    "city",
    "district",
    "education",
    "experience",
    "salary_raw",
    "salary_min",
    "salary_max",
    "job_description",
    "job_url",
    "crawl_date"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "description": "岗位唯一编号，由 ncss source_job_id 映射。"
    },
    "job_name": {
      "type": "string",
      "description": "岗位名称。"
    },
    "job_category": {
      "type": "string",
      "description": "标准岗位类别，当前为空，后续自动分类。"
    },
    "company_name": {
      "type": "string",
      "description": "企业名称。"
    },
    "industry": {
      "type": "string",
      "description": "所属行业。"
    },
    "company_scale": {
      "type": "string",
      "description": "企业规模。"
    },
    "city": {
      "type": "string",
      "description": "经验证的工作城市；无法细分的省级地点不参与城市维度统计。"
    },
    "district": {
      "type": "string",
      "description": "工作区域。ncss 当前多数为空。"
    },
    "education": {
      "type": "string",
      "description": "学历要求。"
    },
    "experience": {
      "type": "string",
      "description": "工作经验要求。ncss 当前多数为空。"
    },
    "salary_raw": {
      "type": "string",
      "description": "原始薪资文本。"
    },
    "salary_min": {
      "type": ["integer", "string"],
      "description": "最低月薪，单位为元；无法解析时为空字符串。"
    },
    "salary_max": {
      "type": ["integer", "string"],
      "description": "最高月薪，单位为元；无法解析时为空字符串。"
    },
    "job_description": {
      "type": "string",
      "description": "完整岗位描述。"
    },
    "job_url": {
      "type": "string",
      "description": "岗位详情链接。"
    },
    "crawl_date": {
      "type": "string",
      "description": "采集日期，格式 YYYY-MM-DD。"
    }
  },
  "additionalProperties": false
}
